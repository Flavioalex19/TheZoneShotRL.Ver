      m_Calls: []
  m_text: "Team Style: Each team has its own playing style that gives position-based
    bonuses. Good player positioning is key to maximizing these advantages.\r\nBudget
    (Quantum): This is your weekly resource used for training and transfers. Spend
    it carefully or save it for critical moments.\r\nMorale: Acts as your team\u2019s
    thermometer. If it reaches zero, you get fired. Low morale have secret properties"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: c58c75c6426699c48935050f28fd80dd, type: 2}
