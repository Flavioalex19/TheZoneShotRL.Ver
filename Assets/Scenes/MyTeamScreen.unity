    - target: {fileID: 4315932971525939294, guid: e17764010848dc94fad0ede0df41355d, type: 3}
      propertyPath: m_text
      value: "Alright, Boss, let\u2019s get you up to speed! This is your main menu,
        your command center for world domination! Well, league domination, anyway.
        Your job? Build a championship team, manage your players, and keep the fans
        screaming your name. The loop\u2019s simple: draft your squad, make smart
        weekly moves, and crush it on the field. I\u2019ll make you look good, promise!"
      objectReference: {fileID: 0}
