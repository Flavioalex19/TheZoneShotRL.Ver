    - target: {fileID: 4315932971525939294, guid: e17764010848dc94fad0ede0df41355d, type: 3}
      propertyPath: m_text
      value: "Contracts are the name of the game, Boss! Each player\u2019s got a
        ticking clock: Once their games are up, poof, they\u2019re outta here, and
        you\u2019ll need to draft a new random player. You can try to renew one contract
        per week, but sometimes they stay, sometimes they ditch. Choose who\u2019s
        worth the shot, \u2018cause even I can\u2019t charm \u2018em all!"
      objectReference: {fileID: 0}
