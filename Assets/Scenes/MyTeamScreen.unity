    - target: {fileID: 4315932971525939294, guid: e17764010848dc94fad0ede0df41355d, type: 3}
      propertyPath: m_text
      value: "Feeling like a player\u2019s not cutting it? Once a week, you can trade
        one guy for a fresh random recruit. It\u2019s a chance to shake things up,
        but choose carefully, new blood\u2019s not always better. Lucky for you,
        I\u2019ve got an eye for talent, so follow my lead, and we\u2019ll build
        a dynasty!"
      objectReference: {fileID: 0}
