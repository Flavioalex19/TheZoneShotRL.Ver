    - target: {fileID: 4845152673167491535, guid: 30c6f40278f2a98469fe98cc26332de9, type: 3}
      propertyPath: m_text
      value: 'Match

'
      objectReference: {fileID: 0}
    - target: {fileID: 6563504826612088725, guid: 30c6f40278f2a98469fe98cc26332de9, type: 3}
      propertyPath: m_text
      value: 'To use your SP Skill, check the side of the screen to see your available
        SP Points. The number of SP Points you have depends on your Fan Support level.

        What
        is the SP Skill? Each team has a unique playstyle defined by two attributes.
        These attributes unlock a super-powerful SP Skill that can score big points
        in a match. When successful, an SP Skill scores more than any regular shot,
        giving you a game-changing advantage!'
      objectReference: {fileID: 0}
    - target: {fileID: 6563504826612088725, guid: 30c6f40278f2a98469fe98cc26332de9, type: 3}
      propertyPath: m_fontSize
